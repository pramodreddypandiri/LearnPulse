{
  "manifest_version": 3,
  "name": "LearnPulse",
  "version": "0.1.0",
  "description": "Automatically captures your search history and generates reflective LinkedIn + X posts about your daily learning.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LearnPulse — View today's learning"
  },

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["dist/content-google.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["dist/content-perplexity.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["dist/content-learnpulse.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "history",
    "storage",
    "scripting",
    "alarms",
    "notifications",
    "tabs"
  ],

  "host_permissions": [
    "https://www.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "http://localhost:3000/*"
  ]
}
